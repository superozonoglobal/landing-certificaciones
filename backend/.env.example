# Super Ozono Global — Variables de Entorno
# ⚠️  NO subir este archivo a Git (ya está en .gitignore)
# Copia este archivo como .env y ajusta los valores

# Puerto del servidor
PORT=3001

# Clave secreta para acceder a las rutas administrativas de la API
# Cambia esto en producción por algo robusto:
# openssl rand -hex 32
API_KEY=CAMBIA_ESTA_CLAVE_EN_PRODUCCION

# Orígenes permitidos (CORS) — separa con comas
ALLOWED_ORIGINS=https://certificacion.superozonoglobal.com
